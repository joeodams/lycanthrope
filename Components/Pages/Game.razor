@page "/game/{Id:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using lycanthrope.Components.Shared
@using lycanthrope.Interfaces
@using lycanthrope.Models
@using lycanthrope.Services
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using GameLobby = lycanthrope.Models.Lobby

@inject IGameEngineService GameEngineService
@inject NavigationManager NavigationManager

<PageTitle>Game</PageTitle>

<div class="game-shell">
    <MistLayer />
    @if (!string.IsNullOrWhiteSpace(initializationError))
    {
        <section class="game-panel">
            <h1>Game unavailable</h1>
            <p>@initializationError</p>
            <a class="game-link" href="/?lobbyId=@Id">Return to the landing page</a>
        </section>
    }
    else if (gameView is null)
    {
        <section class="game-panel">
            <h1>Joining game</h1>
            <p>@(connectionMessage ?? "Connecting to the game...")</p>
        </section>
    }
    else
    {
        <section class="game-panel">
            <div class="game-header">
                <div class="game-titleblock">
                    <p class="game-overline">@PhaseLabel</p>
                    <h1>@PhaseHeading</h1>
                </div>
                <div class="game-meta">
                    <span class="game-meta-chip">
                        <strong>Role</strong>
                        <span>@CurrentPlayer.Role</span>
                    </span>
                    <span class="game-meta-chip">
                        <strong>Status</strong>
                        <span>@(CurrentPlayer.Alive ? "Alive" : "Dead")</span>
                    </span>
                    @if (IsHost)
                    {
                        <span class="game-meta-chip">
                            <strong>Burden</strong>
                            <span>Host controls phase</span>
                        </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(connectionMessage))
                    {
                        <span class="game-meta-chip">
                            <strong>Connection</strong>
                            <span>@connectionMessage</span>
                        </span>
                    }
                    <span class="game-meta-chip game-meta-chip-omen">
                        <strong>Latest Omen</strong>
                        <span>@LatestOmenText</span>
                    </span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="game-message game-message-error game-banner">@errorMessage</p>
            }

            <section class="game-card game-story">
                <div class="game-story-pane game-story-pane-role">
                    <h2>Your role is @CurrentPlayer.Role.</h2>
                    <p>@RoleDescription</p>
                    @if (!string.IsNullOrWhiteSpace(gameView.PrivateNote))
                    {
                        <p class="game-private">@gameView.PrivateNote</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(ActionProgressText))
                    {
                        <p class="game-story-progress">@ActionProgressText</p>
                    }
                </div>
            </section>

            <div class="game-grid">
                <section class="game-card game-roster-card">
                    <div class="game-roster">
                        @foreach (var player in Lobby.Players)
                        {
                            <div class="game-player @(player.Alive ? string.Empty : "game-player-dead")">
                                <div class="game-player-identity">
                                    <span class="game-player-mark @(GetPlayerStatusClass(player))"></span>
                                    <div>
                                        <strong>@player.Name</strong>
                                        <div class="game-player-badges">
                                            @if (player.IsBot)
                                            {
                                                <span class="game-badge">Bot</span>
                                            }
                                            @if (player.Id == Lobby.HostPlayerId)
                                            {
                                                <span class="game-badge">Host</span>
                                            }
                                            @if (player.Id == PlayerId)
                                            {
                                                <span class="game-badge">You</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <span>@(player.Alive ? "Alive" : "Dead")</span>
                            </div>
                        }
                    </div>
                </section>

                <section class="game-card game-command">
                    <div class="game-decision">
                        <div class="game-section-header">
                            <div>
                                <p class="game-section-kicker">Decision</p>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ActionProgressText))
                            {
                                <span class="game-section-stat">@ActionProgressText</span>
                            }
                        </div>
                        @if (!CurrentPlayer.Alive && Lobby.Phase != Phase.GameOver)
                        {
                            <p>After your death, only your restless, lingering spirit bears witness to events.</p>
                        }
                        else if (Lobby.Phase == Phase.GameOver)
                        {
                            <p>@(Lobby.Winner ?? "No one") won the game.</p>
                        }
                        else if (Lobby.Phase == Phase.Dawn)
                        {
                            <p>It seems dark forces have been at work. The living gather themselves to face what the morning
                                brings...
                            </p>
                        }
                        else if (Lobby.Phase == Phase.Night)
                        {
                            @if (AvailableNightAction is null)
                            {
                                <p>You sleep fitfully.</p>
                            }
                            else
                            {
                                <p>@NightActionPrompt</p>
                                <div class="game-targets">
                                    @foreach (var target in NightTargets)
                                    {
                                        <button
                                            class="game-button @(IsCurrentNightTarget(target.Id) ? "game-button-active" : string.Empty)"
                                            @onclick="() => SubmitNightActionAsync(target.Id)" disabled="@isBusy">
                                            @GetNightActionLabel(target.Name)
                                        </button>
                                    }
                                </div>
                                @if (gameView.SubmittedNightAction?.TargetId is Guid targetId)
                                {
                                    <p>You selected @GetPlayerName(targetId).</p>
                                }
                            }
                        }
                        else if (Lobby.Phase == Phase.Day)
                        {
                            <p>The time has come to cast the guilty out.</p>
                            <div class="game-targets">
                                @foreach (var target in VoteTargets)
                                {
                                    <button
                                        class="game-button @(gameView.SubmittedVoteTargetId == target.Id ? "game-button-active" : string.Empty)"
                                        @onclick="() => SubmitVoteAsync(target.Id)" disabled="@isBusy">
                                        Vote for @target.Name
                                    </button>
                                }
                            </div>
                            @if (gameView.SubmittedVoteTargetId is Guid votedTargetId)
                            {
                                <p>You voted for @GetPlayerName(votedTargetId).</p>
                            }
                        }
                    </div>

                    <section class="game-chat">
                        <div class="game-section-header game-chat-header">
                            <div>
                                <p class="game-section-kicker">Whispers</p>
                            </div>
                        </div>

                        <div class="game-chat-log">
                            @if (Lobby.RecentMessages.Count == 0)
                            {
                                <p class="game-chat-empty">The circle is silent.</p>
                            }
                            else
                            {
                                @foreach (var message in Lobby.RecentMessages)
                                {
                                    <article class="game-chat-message @(GetGameChatMessageClass(message))">
                                        <div class="game-chat-meta @(message.IsSystem ? "game-chat-meta-system" : string.Empty)">
                                            @if (!message.IsSystem)
                                            {
                                                <strong>@message.SenderName</strong>
                                            }
                                            <span>@message.CreatedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                                        </div>
                                        <p>@message.Body</p>
                                    </article>
                                }
                            }
                        </div>

                        <form class="game-chat-compose" @onsubmit="SendChatMessageAsync" @onsubmit:preventDefault>
                            <input class="game-chat-input" @bind="chatMessage" @bind:event="oninput" maxlength="280"
                                   placeholder="@ChatPlaceholder" disabled="@(!CanSendChat)" />
                            <button class="game-button" type="submit"
                                    disabled="@(!CanSendChat || string.IsNullOrWhiteSpace(chatMessage))">
                                Send
                            </button>
                        </form>
                    </section>

                    <div class="game-actions">
                        @if (CanAdvancePhase)
                        {
                            <button class="game-button game-button-primary" @onclick="AdvancePhaseAsync" disabled="@isBusy">
                                @AdvancePhaseLabel
                            </button>
                        }

                        <button class="game-button" @onclick="LeaveAsync" disabled="@isBusy">
                            Leave game
                        </button>
                    </div>
                </section>
            </div>
        </section>
    }
</div>

@code
{
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromQuery]
    public string PlayerName { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public Guid PlayerId { get; set; }

    private GameView gameView;
    private HubConnection hub;
    private string connectionMessage = string.Empty;
    private string errorMessage = string.Empty;
    private string initializationError = string.Empty;
    private string chatMessage = string.Empty;
    private bool isBusy;
    private bool isLeaving;

    private GameLobby Lobby => gameView.Lobby;

    private Player CurrentPlayer => gameView.CurrentPlayer;

    private bool IsHost => Lobby.HostPlayerId == PlayerId;

    private bool CanAdvancePhase => IsHost && Lobby.Phase is Phase.Night or Phase.Dawn or Phase.Day;

    private bool IsChatOpen => Lobby.Phase is Phase.Setup or Phase.Dawn or Phase.Day or Phase.GameOver;

    private bool CanSpeakInChat => CurrentPlayer.Alive || Lobby.Phase == Phase.GameOver;

    private bool CanSendChat => gameView is not null && IsChatOpen && CanSpeakInChat && !isBusy;

    private NightAct? AvailableNightAction =>
        CurrentPlayer.Role switch
        {
            Role.Werewolf => NightAct.Kill,
            Role.Seer => NightAct.Inspect,
            Role.Doctor => NightAct.Protect,
            _ => null,
        };

    private IEnumerable<Player> NightTargets =>
        AvailableNightAction switch
        {
            NightAct.Kill => Lobby.Players.Where(player =>
                player.Alive && player.Id != PlayerId && player.Role != Role.Werewolf
            ),
            NightAct.Inspect => Lobby.Players.Where(player => player.Alive && player.Id != PlayerId),
            NightAct.Protect => Lobby.Players.Where(player => player.Alive),
            _ => Enumerable.Empty<Player>(),
        };

    private IEnumerable<Player> VoteTargets =>
        Lobby.Players.Where(player => player.Alive && player.Id != PlayerId);

    private string PhaseLabel =>
        Lobby.Phase switch
        {
            Phase.Night => $"Night {Lobby.DayCount}",
            Phase.Dawn => $"Dawn {Lobby.DayCount}",
            Phase.Day => $"Day {Lobby.DayCount}",
            Phase.GameOver => "Game Over",
            _ => "Lobby",
        };

    private string PhaseHeading =>
        Lobby.Phase switch
        {
            Phase.Night => "Night falls",
            Phase.Dawn => "Dawn breaks",
            Phase.Day => "Fates will be decided",
            Phase.GameOver => "The game is over",
            _ => "Waiting in the lobby",
        };

    private string LatestOmenText =>
        string.IsNullOrWhiteSpace(Lobby.LatestEvent)
            ? "The village listens for the next sign."
            : Lobby.LatestEvent;

    private string ChatPlaceholder =>
        !IsChatOpen
            ? "Your voice only falls on the blackness of the night."
            : !CanSpeakInChat
                ? "Your frail, ghostly voice is inaudible to the living."
                : "Accuse, warn, or beg for mercy...";

    private string RoleDescription =>
        CurrentPlayer.Role switch
        {
            Role.Werewolf =>
                "Avoid the gaze of suspicion. Strike at night as one.",
            Role.Seer =>
                "The gift of sight allows you a glimpse of the truth behind the veil.",
            Role.Doctor =>
                "Life can sometimes be spared with skill, but whose?",
            _ =>
                "The weak suffer what they must.",
        };

    private string ActionProgressText =>
        Lobby.Phase switch
        {
            Phase.Night => $"{gameView.SubmittedNightActions}/{gameView.RequiredNightActions} night actions submitted.",
            Phase.Day => $"{gameView.SubmittedVotes}/{gameView.RequiredVotes} votes submitted.",
            _ => string.Empty,
        };

    private string AdvancePhaseLabel =>
        Lobby.Phase switch
        {
            Phase.Night => "Awaken the village...",
            Phase.Dawn => "The time for judgement is at hand...",
            Phase.Day => "The votes are cast...",
            _ => "Continue",
        };

    private string NightActionPrompt =>
        AvailableNightAction switch
        {
            NightAct.Kill => "The smell of blood allures you, but the pack must act as one.",
            NightAct.Inspect => "Learn what you will of the treachery of one.",
            NightAct.Protect => "Perhaps a soul can be saved tonight, but who of these are worthy?",
            _ => string.Empty,
        };

    protected override async Task OnInitializedAsync()
    {
        if (PlayerId == Guid.Empty || string.IsNullOrWhiteSpace(PlayerName))
        {
            NavigationManager.NavigateTo($"/?lobbyId={Id}");
            return;
        }

        await ConnectToGameAsync();
    }

    private async Task ConnectToGameAsync()
    {
        hub = new HubConnectionBuilder()
            .WithUrl(
                NavigationManager.ToAbsoluteUri(
                    $"/lobbyhub?lobbyId={Id}&playerId={PlayerId}&playerName={Uri.EscapeDataString(PlayerName)}"
                )
            )
            .WithAutomaticReconnect()
            .Build();

        hub.On(LobbyHub.LobbyUpdatedMethod, ReloadGameAsync);

        hub.Reconnecting += _ =>
        {
            connectionMessage = "Connection dropped. Reconnecting...";
            return InvokeAsync(StateHasChanged);
        };

        hub.Reconnected += async _ =>
        {
            connectionMessage = "Reconnected to the game.";
            await ReloadGameAsync();
        };

        hub.Closed += _ =>
        {
            if (!isLeaving)
            {
                connectionMessage = "Disconnected from the game.";
            }

            return InvokeAsync(StateHasChanged);
        };

        try
        {
            connectionMessage = "Connecting to the game...";
            await hub.StartAsync();
            await ReloadGameAsync();
            connectionMessage = "Connected.";
        }
        catch (HubException ex)
        {
            initializationError = ex.Message;
        }
        catch
        {
            initializationError = "Unable to connect to this game right now.";
        }
    }

    private async Task ReloadGameAsync()
    {
        try
        {
            gameView = await GameEngineService.GetGameViewAsync(Id, PlayerId);
        }
        catch (InvalidOperationException)
        {
            if (!isLeaving)
            {
                NavigationManager.NavigateTo($"/?lobbyId={Id}");
            }

            return;
        }

        if (!isLeaving && Lobby.Phase == Phase.Setup)
        {
            await PrepareForPageTransitionAsync();
            NavigationManager.NavigateTo(
                $"/lobby/{Id}?playerId={PlayerId}&playerName={Uri.EscapeDataString(PlayerName)}"
            );
            return;
        }

        errorMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private Task SubmitNightActionAsync(Guid targetId)
    {
        if (AvailableNightAction is null)
        {
            return Task.CompletedTask;
        }

        return RunGameActionAsync(
            () => GameEngineService.SubmitNightActionAsync(
                Id,
                new NightAction(PlayerId, AvailableNightAction.Value, targetId)
            )
        );
    }

    private Task SubmitVoteAsync(Guid targetId) =>
        RunGameActionAsync(() => GameEngineService.SubmitVoteAsync(Id, PlayerId, targetId));

    private Task AdvancePhaseAsync() =>
        RunGameActionAsync(() => GameEngineService.AdvancePhaseAsync(Id, PlayerId));

    private async Task SendChatMessageAsync()
    {
        var messageToSend = chatMessage;
        if (string.IsNullOrWhiteSpace(messageToSend))
        {
            return;
        }

        await RunGameActionAsync(
            () => GameEngineService.SendChatMessageAsync(Id, PlayerId, messageToSend)
        );

        if (string.IsNullOrWhiteSpace(errorMessage))
        {
            chatMessage = string.Empty;
        }
    }

    private async Task LeaveAsync()
    {
        if (hub is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        await RunGameActionAsync(async () =>
        {
            isLeaving = true;
            await hub.SendAsync(nameof(LobbyHub.LeaveLobby));
            await hub.StopAsync();
            NavigationManager.NavigateTo("/");
        });
    }

    private async Task PrepareForPageTransitionAsync()
    {
        if (hub is null)
        {
            return;
        }

        try
        {
            await hub.SendAsync(nameof(LobbyHub.PrepareForPageTransition));
        }
        catch
        {
            // oops
        }
    }

    private async Task RunGameActionAsync(Func<Task> action)
    {
        if (isBusy)
        {
            return;
        }

        isBusy = true;
        errorMessage = string.Empty;

        try
        {
            await action();
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "That action could not be completed.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private bool IsCurrentNightTarget(Guid playerId) =>
        gameView.SubmittedNightAction?.TargetId == playerId;

    private string GetNightActionLabel(string playerName) =>
        $"{GetNightActionVerb()} {playerName}";

    private string GetNightActionVerb() =>
        AvailableNightAction switch
        {
            NightAct.Kill => "Target",
            NightAct.Inspect => "Inspect",
            NightAct.Protect => "Protect",
            _ => "Select",
        };

    private string GetPlayerName(Guid playerId) =>
        Lobby.Players.FirstOrDefault(player => player.Id == playerId)?.Name ?? "that player";

    private string GetGameChatMessageClass(ChatMessage message)
    {
        if (message.IsSystem)
        {
            return "game-chat-message-system";
        }

        return message.SenderPlayerId == PlayerId ? "game-chat-message-self" : string.Empty;
    }

    private string GetPlayerStatusClass(Player player) =>
        player.Alive ? "game-player-mark-alive" : "game-player-mark-dead";

    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
        {
            await hub.DisposeAsync();
        }
    }
}
