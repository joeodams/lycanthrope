@page "/lobby/{id:Guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using lycanthrope.Interfaces
@using lycanthrope.Models

@inject IGameEngineService LobbyService
@inject IJSRuntime JSRuntime;
@inject NavigationManager NavigationManager;
@inject ILogger<Lobby> Log

<h1>Lobby @Id</h1>

<div class="lobby-container">
    @if (lobby is null)
    {
        <p>Loading…</p>
    }
    else
    {
        @foreach (var p in lobby.Players)
        {
            <div>
                <table>
                    <tr>
                        <td>
                            <div>
                                <p>@p.Name</p>
                            </div>
                        </td>
                        <td>
                            <div>
                                @if (p.Ready)
                                {
                                    <p>Ready</p>
                                }
                                else
                                {
                                    <p>not ready</p>
                                }
                            </div>
                        </td>
                        @if (p.Id == PlayerId)
                        {
                            <td>
                                <button @onclick="TogglePlayerReadyAsync">Toggle ready</button>
                            </td>
                        }
                    </tr>
                </table>
            </div>
        }
    }

    <button @onclick="CopyShareLinkAsync">Share lobby link</button>
    <button @onclick="LeaveAsync">Leave</button>
    <button @onclick="StartGameAsync">Start game</button>

</div>

@code
{
    [Parameter] public string Id { get; set; } // the lobbyId in the url
    [SupplyParameterFromQuery] public string PlayerName { get; set; }
    [SupplyParameterFromQuery] public Guid PlayerId { get; set; }

    private lycanthrope.Models.Lobby lobby;
    private HubConnection hub;

    protected override async Task OnInitializedAsync()
    {
        var lobbyId = Guid.Parse(Id);
        var me = new Player(PlayerId, PlayerName);

        // --- SignalR --------------------------------------------------------
        hub = new HubConnectionBuilder()
        .WithUrl(NavigationManager.ToAbsoluteUri($"/lobbyhub?lobbyId={lobbyId}"))
        .WithAutomaticReconnect()
        .Build();

        // 1. register callbacks BEFORE you StartAsync()
        hub.On<string>("ReceivePlayerJoined", async (name) =>
        {
            lobby = await LobbyService.GetLobbyByIdAsync(lobbyId); // pull fresh state
            await InvokeAsync(StateHasChanged);
        });

        hub.On<string>("ReceivePlayerLeft", async (name) =>
        {
            lobby = await LobbyService.GetLobbyByIdAsync(lobbyId);
            await InvokeAsync(StateHasChanged);
        });

        hub.On<string>("ReceivePlayerReadyToggle", async (name) =>
        {
            lobby = await LobbyService.GetLobbyByIdAsync(lobbyId);
            await InvokeAsync(StateHasChanged);
        });

        hub.On<string>("ReceiveGameStarted", async (name) =>
        {
            lobby = await LobbyService.GetLobbyByIdAsync(lobbyId);
            await InvokeAsync(StateHasChanged);
        });

        hub.On("ReceiveGameStarted", async () =>
        {
            await InvokeAsync(() => RouteToGamePage());
        });

        await hub.StartAsync();
        //---------------------------------------------------------------------

        // 2. add yourself to the lobby (server side)
        lobby = await LobbyService.AddPlayerToLobbyAsync(lobbyId, me);

        // 3. notify other clients
        await hub.SendAsync("PlayerJoined", lobbyId.ToString(), me.Name);
    }

    private async Task CopyShareLinkAsync()
    {
        var url = $"{NavigationManager.BaseUri}?lobbyId={lobby.Id}";
        await JSRuntime.InvokeVoidAsync("copyToClipboard", url);
    }

    private async Task TogglePlayerReadyAsync()
    {

        await LobbyService.TogglePlayerReadyAsync(Guid.Parse(Id), PlayerId);
        await hub.SendAsync("PlayerReadyToggle", Id, PlayerName);

    }

    private void RouteToGamePage()
    {
        NavigationManager.NavigateTo($"/game/{Id}" +
        $"?playerId={PlayerId}&playerName={Uri.EscapeDataString(PlayerName)}");
    }

    private async Task LeaveAsync()
    {
        await hub.SendAsync("PlayerLeft", Id, PlayerName);
        NavigationManager.NavigateTo("/");
    }

    private async Task StartGameAsync()
    {
        await LobbyService.StartGameAsync(Guid.Parse(Id));
        await hub.SendAsync("GameStarted", Id, PlayerName);
    }

    public async ValueTask DisposeAsync()
    {
        if (hub is not null) await hub.DisposeAsync();
    }
}
