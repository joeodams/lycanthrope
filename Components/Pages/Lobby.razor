@page "/lobby/{Id:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using lycanthrope.Interfaces
@using lycanthrope.Models
@using lycanthrope.Services
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Http.Connections

@inject IGameEngineService LobbyService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>Lobby</PageTitle>

<div class="lobby-shell">
    @if (!string.IsNullOrWhiteSpace(initializationError))
    {
        <section class="lobby-panel">
            <h1>Lobby unavailable</h1>
            <p>@initializationError</p>
            <a class="lobby-link" href="/?lobbyId=@Id">Return to the landing page</a>
        </section>
    }
    else if (lobby is null)
    {
        <section class="lobby-panel">
            <h1>Joining lobby</h1>
            <p>@(connectionMessage ?? "Connecting to the lobby...")</p>
        </section>
    }
    else
    {
        <section class="lobby-panel">
            <div class="lobby-header">
                <div>
                    <h1>Lobby</h1>
                    <p class="lobby-subtitle">Share this invite and get everyone ready.</p>
                </div>
                <div class="lobby-meta">
                    <span>Code: @lobby.Id</span>
                    <span>Phase: @lobby.Phase</span>
                    <span>@PlayersReady / @lobby.Players.Count ready</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(connectionMessage))
            {
                <p class="lobby-message">@connectionMessage</p>
            }

            @if (!string.IsNullOrWhiteSpace(feedbackMessage))
            {
                <p class="lobby-message">@feedbackMessage</p>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="lobby-message lobby-message-error">@errorMessage</p>
            }

            <div class="lobby-roster">
                @foreach (var player in lobby.Players)
                {
                    <div class="player-row @(player.Id == PlayerId ? "player-row-self" : string.Empty)">
                        <div>
                            <strong>@player.Name</strong>
                            @if (player.IsBot)
                            {
                                <span class="player-badge">Bot</span>
                            }
                            @if (player.Id == lobby.HostPlayerId)
                            {
                                <span class="player-badge">Host</span>
                            }
                            @if (player.Id == PlayerId)
                            {
                                <span class="player-badge">You</span>
                            }
                        </div>
                        <div class="player-state">
                            @if (lobby.Phase == Phase.Setup)
                            {
                                <span>@(player.Ready ? "Ready" : "Waiting")</span>
                            }
                            else
                            {
                                <span>@(player.Alive ? "Alive" : "Out")</span>
                            }
                        </div>
                    </div>
                }
            </div>

            <section class="lobby-chat">
                <div class="lobby-chat-header">
                    <h2>Lobby chat</h2>
                    <span>@lobby.RecentMessages.Count messages</span>
                </div>

                <div class="lobby-chat-log">
                    @if (lobby.RecentMessages.Count == 0)
                    {
                        <p class="lobby-chat-empty">Nothing but the howling wind...</p>
                    }
                    else
                    {
                        @foreach (var message in lobby.RecentMessages)
                        {
                            <article class="lobby-chat-message @(GetLobbyChatMessageClass(message))">
                                <div class="lobby-chat-meta">
                                    <strong>@GetChatAuthor(message)</strong>
                                    <span>@message.CreatedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                                <p>@message.Body</p>
                            </article>
                        }
                    }
                </div>

                <form class="lobby-chat-compose" @onsubmit="SendChatMessageAsync" @onsubmit:preventDefault>
                    <input class="lobby-chat-input" @bind="chatMessage" @bind:event="oninput" maxlength="280"
                           placeholder="Say something to the lobby..." disabled="@(!CanSendChat)" />
                    <button class="lobby-button" type="submit"
                            disabled="@(!CanSendChat || string.IsNullOrWhiteSpace(chatMessage))">
                        Send
                    </button>
                </form>
            </section>

            <div class="lobby-actions">
                <button class="lobby-button" @onclick="CopyShareLinkAsync" disabled="@isBusy">
                    Share lobby link
                </button>
                <button class="lobby-button" @onclick="TogglePlayerReadyAsync" disabled="@(!CanToggleReady || isBusy)">
                    @(CurrentPlayer is not null && CurrentPlayer.Ready ? "Mark not ready" : "Mark ready")
                </button>
                <button class="lobby-button" @onclick="FillSeatsAsync" disabled="@(!CanFillSeats || isBusy)">
                    Fill seats
                </button>
                <button class="lobby-button lobby-button-primary" @onclick="StartGameAsync"
                        disabled="@(!CanStartGame || isBusy)">
                    Start game
                </button>
                <button class="lobby-button" @onclick="LeaveAsync" disabled="@isBusy">
                    Leave
                </button>
            </div>

            <p class="lobby-note">@StartRequirements</p>
        </section>
    }
</div>

@code
{
    private const int MinimumPlayersToStart = 4;

    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromQuery]
    public string PlayerName { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public Guid PlayerId { get; set; }

    private Models.Lobby lobby;
    private HubConnection hub;
    private string connectionMessage = string.Empty;
    private string feedbackMessage = string.Empty;
    private string errorMessage = string.Empty;
    private string initializationError = string.Empty;
    private string chatMessage = string.Empty;
    private bool isBusy;
    private bool isLeaving;

    private Player CurrentPlayer => lobby?.Players.FirstOrDefault(player => player.Id == PlayerId);

    private int PlayersReady => lobby?.Players.Count(player => player.Ready) ?? 0;

    private bool CanToggleReady =>
        lobby is not null && lobby.Phase == Phase.Setup && CurrentPlayer is not null;

    private bool CanFillSeats =>
        lobby is not null
        && lobby.Phase == Phase.Setup
        && lobby.HostPlayerId == PlayerId
        && lobby.Players.Count < MinimumPlayersToStart;

    private bool CanStartGame =>
        lobby is not null
        && lobby.Phase == Phase.Setup
        && lobby.HostPlayerId == PlayerId
        && lobby.Players.Count >= MinimumPlayersToStart
        && lobby.Players.All(player => player.Ready);

    private bool CanSendChat => lobby is not null && lobby.Phase == Phase.Setup && !isBusy;

    private string StartRequirements =>
        lobby is null ? string.Empty
        : lobby.Phase != Phase.Setup ? "The lobby is already in progress."
        : lobby.HostPlayerId != PlayerId ? "Only the host can start the game."
        : lobby.Players.Count < MinimumPlayersToStart
            ? "At least four players are required to start. Fill seats to add bots."
        : lobby.Players.Any(player => !player.Ready)
            ? "Everyone needs to mark ready before the game can begin."
            : "The lobby is ready to start.";

    protected override async Task OnInitializedAsync()
    {
        if (PlayerId == Guid.Empty || string.IsNullOrWhiteSpace(PlayerName))
        {
            NavigationManager.NavigateTo($"/?lobbyId={Id}");
            return;
        }

        await ConnectToLobbyAsync();
    }

    private async Task ConnectToLobbyAsync()
    {
        hub = new HubConnectionBuilder()
            .WithUrl(
                NavigationManager.ToAbsoluteUri(
                    $"/lobbyhub?lobbyId={Id}&playerId={PlayerId}&playerName={Uri.EscapeDataString(PlayerName)}"
                )
            )
            .WithAutomaticReconnect()
            .Build();

        hub.On(LobbyHub.LobbyUpdatedMethod, ReloadLobbyAsync);

        hub.Reconnecting += _ =>
        {
            connectionMessage = "Connection dropped. Reconnecting...";
            return InvokeAsync(StateHasChanged);
        };

        hub.Reconnected += async _ =>
        {
            connectionMessage = "Reconnected to the lobby.";
            await ReloadLobbyAsync();
        };

        hub.Closed += _ =>
        {
            if (!isLeaving)
            {
                connectionMessage = "Disconnected from the lobby.";
            }

            return InvokeAsync(StateHasChanged);
        };

        try
        {
            connectionMessage = "Connecting to the lobby...";
            await hub.StartAsync();
            await ReloadLobbyAsync();
            connectionMessage = "Connected.";
        }
        catch (HubException ex)
        {
            initializationError = ex.Message;
        }
        catch
        {
            initializationError = "Unable to connect to this lobby right now.";
        }
    }

    private async Task ReloadLobbyAsync()
    {
        lobby = await LobbyService.GetLobbyByIdAsync(Id);

        if (!isLeaving && lobby.Players.All(player => player.Id != PlayerId))
        {
            if (hub?.State == HubConnectionState.Connected || hub?.State == HubConnectionState.Connecting)
            {
                connectionMessage = "Joining lobby...";
                await InvokeAsync(StateHasChanged);
                return;
            }

            NavigationManager.NavigateTo($"/?lobbyId={Id}");
            return;
        }

        if (!isLeaving && lobby.Phase != Phase.Setup)
        {
            await PrepareForPageTransitionAsync();
            NavigationManager.NavigateTo(
                $"/game/{Id}?playerId={PlayerId}&playerName={Uri.EscapeDataString(PlayerName)}"
            );
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CopyShareLinkAsync()
    {
        if (lobby is null)
        {
            return;
        }

        var url = $"{NavigationManager.BaseUri}?lobbyId={lobby.Id}";
        await JSRuntime.InvokeVoidAsync("copyToClipboard", url);
        feedbackMessage = "Invite link copied.";
        errorMessage = null;
    }

    private Task TogglePlayerReadyAsync() =>
        RunLobbyActionAsync(() => LobbyService.TogglePlayerReadyAsync(Id, PlayerId));

    private Task FillSeatsAsync() =>
        RunLobbyActionAsync(
            () => LobbyService.FillSeatsAsync(Id, PlayerId),
            "Bot seats added."
        );

    private Task StartGameAsync() =>
        RunLobbyActionAsync(() => LobbyService.StartGameAsync(Id, PlayerId));

    private async Task SendChatMessageAsync()
    {
        var messageToSend = chatMessage;
        if (string.IsNullOrWhiteSpace(messageToSend))
        {
            return;
        }

        await RunLobbyActionAsync(() => LobbyService.SendChatMessageAsync(Id, PlayerId, messageToSend));
        if (string.IsNullOrWhiteSpace(errorMessage))
        {
            chatMessage = string.Empty;
        }
    }

    private async Task LeaveAsync()
    {
        if (hub is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        await RunLobbyActionAsync(async () =>
        {
            isLeaving = true;
            await hub.SendAsync(nameof(LobbyHub.LeaveLobby));
            await hub.StopAsync();
            NavigationManager.NavigateTo("/");
        });
    }

    private async Task PrepareForPageTransitionAsync()
    {
        if (hub is null)
        {
            return;
        }

        try
        {
            await hub.SendAsync(nameof(LobbyHub.PrepareForPageTransition));
        }
        catch
        {
            // Best-effort only. If this fails, the next page load will surface the issue.
        }
    }

    private async Task RunLobbyActionAsync(Func<Task> action, string successMessage = "")
    {
        if (isBusy)
        {
            return;
        }

        isBusy = true;
        feedbackMessage = null;
        errorMessage = null;

        try
        {
            await action();
            feedbackMessage = successMessage;
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "That action could not be completed.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private string GetChatAuthor(ChatMessage message) => message.IsSystem ? "System" : message.SenderName;

    private string GetLobbyChatMessageClass(ChatMessage message)
    {
        if (message.IsSystem)
        {
            return "lobby-chat-message-system";
        }

        return message.SenderPlayerId == PlayerId ? "lobby-chat-message-self" : string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
        {
            await hub.DisposeAsync();
        }
    }
}
