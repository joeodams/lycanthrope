@page "/"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using lycanthrope.Interfaces
@using lycanthrope.Models

@inject IGameEngineService GameEngineService
@inject NavigationManager Navigation

<div class="fullscreen-background">
    <div class="input-container">
        <div class="input-panel">
            <EditForm Model="@player" OnValidSubmit="HandleLobbySubmitAsync" class="name-form">
                <InputText
                    class="name-input"
                    @bind-Value="player.Name"
                    @ref="nameInput"
                    disabled="@isBusy" />
                <div class="landing-actions">
                    <button
                        class="landing-button landing-button-primary"
                        type="submit"
                        disabled="@isBusy">
                        @PrimaryActionLabel
                    </button>
                    <button
                        class="landing-button"
                        type="button"
                        @onclick="HandleDemoGameAsync"
                        disabled="@isBusy">
                        Play Demo
                    </button>
                </div>
            </EditForm>

            <p class="landing-message">@HelperText</p>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="landing-message landing-message-error">@errorMessage</p>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string LobbyId { get; set; } = string.Empty;

    private InputText nameInput;
    private readonly Player player = new();
    private string errorMessage = string.Empty;
    private bool isBusy;

    private string PrimaryActionLabel =>
        string.IsNullOrWhiteSpace(LobbyId) ? "Create Lobby" : "Join Lobby";

    private string HelperText =>
        string.IsNullOrWhiteSpace(LobbyId)
            ? "Press Enter to create a lobby with friends, or launch a bot-filled demo."
            : "Press Enter to join this invite, or launch a separate bot-filled demo.";

    private async Task HandleLobbySubmitAsync()
    {
        if (!TryPreparePlayer(out var encodedPlayerName))
        {
            return;
        }

        var destination = !string.IsNullOrWhiteSpace(LobbyId)
            ? $"/lobby/{LobbyId}?playerName={encodedPlayerName}&playerId={player.Id}"
            : $"/lobby/{Guid.NewGuid()}?playerName={encodedPlayerName}&playerId={player.Id}";

        await NavigateAsync(destination);
    }

    private async Task HandleDemoGameAsync()
    {
        if (!TryPreparePlayer(out var encodedPlayerName))
        {
            return;
        }

        isBusy = true;
        errorMessage = string.Empty;

        try
        {
            var demoLobbyId = await GameEngineService.CreateDemoGameAsync(player);
            await NavigateAsync(
                $"/game/{demoLobbyId}?playerName={encodedPlayerName}&playerId={player.Id}"
            );
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "Unable to create a demo game right now.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private bool TryPreparePlayer(out string encodedPlayerName)
    {
        player.Name = player.Name.Trim();
        if (string.IsNullOrWhiteSpace(player.Name))
        {
            errorMessage = "Enter a name before continuing.";
            encodedPlayerName = string.Empty;
            return false;
        }

        errorMessage = string.Empty;
        encodedPlayerName = Uri.EscapeDataString(player.Name);
        return true;
    }

    private Task NavigateAsync(string destination)
    {
        Navigation.NavigateTo(destination);
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (nameInput?.Element != null)
        {
            await nameInput.Element.Value.FocusAsync();
        }
    }
}
